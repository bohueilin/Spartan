# Spartan — example environment configuration.
# Copy to `.env` (gitignored) for local tooling, and mirror the values you need
# into `local.properties` (also gitignored) so Gradle can expose them as BuildConfig fields.
#
# NEVER commit real secrets. `.env` and `local.properties` must stay untracked.
# Spartan ships with a MOCK WHOOP client and a STUB Google Calendar client, so the app
# builds and runs with NONE of these set. Provide them only to enable the real integrations.

# ----------------------------------------------------------------------------
# WHOOP OAuth 2.0 (https://developer.whoop.com) — authorization-code flow.
# Least-privilege scopes requested by Spartan:
#   read:recovery read:sleep read:workout read:cycles read:profile read:body_measurement offline
# ----------------------------------------------------------------------------
WHOOP_CLIENT_ID=your_whoop_client_id
WHOOP_CLIENT_SECRET=your_whoop_client_secret
WHOOP_REDIRECT_URI=com.spartan.oauth://whoop
# API base (do not change unless WHOOP moves it):
WHOOP_API_BASE_URL=https://api.prod.whoop.com/developer
WHOOP_AUTH_URL=https://api.prod.whoop.com/oauth/oauth2/auth
WHOOP_TOKEN_URL=https://api.prod.whoop.com/oauth/oauth2/token

# ----------------------------------------------------------------------------
# Google Calendar OAuth 2.0 — least privilege.
# Prefer read-only free/busy; request calendar.events ONLY when the user opts into
# Spartan creating calendar events for scheduled activities.
#   Scope (availability):     https://www.googleapis.com/auth/calendar.freebusy
#   Scope (optional writes):  https://www.googleapis.com/auth/calendar.events
# ----------------------------------------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_REDIRECT_URI=com.spartan.oauth://google

# ----------------------------------------------------------------------------
# Feature flags. Default TRUE => the app uses the MOCK WHOOP client and STUB
# Calendar client (safe, no network, no credentials). Set to false to use the
# real integrations. These map to BuildConfig.USE_MOCK_WHOOP / USE_MOCK_CALENDAR.
# ----------------------------------------------------------------------------
SPARTAN_USE_MOCK_WHOOP=true
SPARTAN_USE_MOCK_CALENDAR=true
